{
  "manifest_version": 2,
  "name": "Penche Scraper",
  "version": "1.0.0",
  "description": "One-keystroke CTI forum scraper — captures title, URL, and screenshot to Taiga or any webhook.",

  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "<all_urls>"
  ],

  "background": {
    "scripts": ["src/background/index.ts"],
    "persistent": false
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],

  "browser_action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Penche Scraper"
  },

  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },

  "commands": {
    "capture": {
      "suggested_key": {
        "default": "Ctrl+Shift+X"
      },
      "description": "Capture current page"
    }
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "penche@penche.local",
      "strict_min_version": "109.0"
    }
  }
}
